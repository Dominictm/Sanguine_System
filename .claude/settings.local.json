{
  "permissions": {
    "allow": [
      "Read(//c/Users/Vuf/.claude/**)",
      "WebFetch(domain:wod.su)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git merge *)",
      "Bash(node -e ' *)",
      "Bash(Start-Process node *)",
      "Bash(Select-Object -ExpandProperty Id)",
      "Bash(node server.js)",
      "Bash(pkill -f \"node server.js\")",
      "PowerShell(Stop-Process -Name \"node\" -Force -ErrorAction SilentlyContinue)",
      "PowerShell(Get-Process -Name \"node\" -ErrorAction SilentlyContinue)",
      "Bash(node --check web/server.js)",
      "Bash(node --check web/public/scripts/scripts.js)",
      "Bash(timeout 5 node server.js)",
      "Bash(timeout 20 node -e \"require\\('./server.js'\\)\")",
      "Bash(python3 -m json.tool --no-ensure-ascii)",
      "Bash(curl -s -X POST http://localhost:4295/api/restart)",
      "Bash(curl -s http://localhost:4295/api/status)",
      "Bash(curl -s http://localhost:4295/api/characters)",
      "Bash(curl -s \"http://localhost:4295/api/characters?city=balmont\")",
      "Bash(curl -v http://localhost:4295/api/status)",
      "PowerShell(Invoke-WebRequest -Uri \"http://localhost:4295/api/status\")",
      "Bash(cat /tmp/server.log | tail -50)",
      "Read(//tmp/**)",
      "Skill(impeccable)",
      "Skill(impeccable:*)",
      "PowerShell(node .claude/skills/impeccable/scripts/context.mjs --target web/public)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PROJECT_DIR}/.claude/skills/impeccable/scripts/hook.mjs\"",
            "timeout": 5,
            "statusMessage": "Checking UI changes"
          }
        ]
      }
    ]
  },
  "description": "Impeccable design detector: runs after Edit/Write/MultiEdit on UI files and surfaces findings as system reminders."
}
