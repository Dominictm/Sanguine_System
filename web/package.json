{
  "name": "sanguine-system",
  "version": "1.0.0",
  "description": "Local web UI for Sanguine System",
  "main": "server.js",
  "scripts": {
    "start": "node wrapper.js",
    "start:bare": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporter.js --test-reporter-destination=nul tests/all.test.js tests/e2e.test.js",
    "test:unit": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporter.js --test-reporter-destination=nul tests/all.test.js",
    "test:e2e": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporter.js --test-reporter-destination=nul tests/e2e.test.js",
    "test:all": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporter.js --test-reporter-destination=nul tests/all.test.js tests/e2e.test.js",
    "test:ui": "node --test --test-reporter=spec --test-reporter-destination=stdout --test-reporter=./tests/reporter.js --test-reporter-destination=nul tests/ui.test.js",
    "test:tap": "node --test --test-reporter=tap tests/all.test.js tests/e2e.test.js",
    "test:ci": "node --test --test-reporter=spec tests/all.test.js tests/e2e.test.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.102.0",
    "@google/genai": "^2.10.0",
    "compression": "^1.8.1",
    "express": "^4.18.2",
    "undici": "^8.5.0"
  },
  "devDependencies": {
    "selenium-webdriver": "^4.44.0"
  }
}
